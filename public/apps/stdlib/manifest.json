{
    "name": "stdlib",
    "version": "1.0.0",
    "description": "SentryOS standard library — reusable utility modules.",
    "author": "SentryOS Team",
    "permissions": [
        "env.library.load"
    ],
    "apps": [
        {
            "id": "stdlib-math",
            "name": "Math Utils",
            "main": "math.js",
            "type": "Library"
        },
        {
            "id": "stdlib-string",
            "name": "String Utils",
            "main": "string.js",
            "type": "Library"
        },
        {
            "id": "stdlib-ui",
            "name": "UI Utils",
            "main": "ui.js",
            "type": "Library"
        },
        {
            "id": "stdlib-i18n",
            "name": "i18n",
            "main": "i18n.js",
            "type": "Library"
        }
    ]
}
