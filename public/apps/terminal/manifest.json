{
    "name": "Terminal",
    "description": "A terminal emulator package for SentryOS.",
    "author": "SentryOS Team",
    "apps": [
        {
            "id": "terminal-app",
            "name": "Terminal",
            "version": "1.0.0",
            "main": "main.js",
            "type": "Console",
            "icon": "icon.svg",
            "permissions": [
                "console.write",
                "console.read",
                "env.library.load",
                "env.read",
                "process.list",
                "process.terminate",
                "shell.apps",
                "shell.launch",
                "shell.windows",
                "shell.sysinfo"
            ],
            "maxInstances": 8
        }
    ]
}