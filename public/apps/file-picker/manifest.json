{
    "name": "File Picker",
    "description": "System file/folder picker dialog.",
    "author": "SentryOS Team",
    "apps": [
        {
            "id": "file-picker-app",
            "name": "File Picker",
            "version": "1.0.0",
            "main": "main.js",
            "type": "Window",
            "icon": "📂",
            "permissions": [
                "window.create",
                "event.subscribe.window.ui",
                "event.emit.window.ui",
                "env.library.load",
                "file.read.user",
                "file.write.user",
                "file.list.user",
                "file.list-all",
                "notification.send",
                "dialog.resolve"
            ],
            "maxInstances": 4,
            "hidden": true
        }
    ]
}
