{
    "name": "Settings",
    "description": "SentryOS system settings \u2013 wallpaper, accent colour, taskbar opacity.",
    "author": "SentryOS Team",
    "apps": [
        {
            "id": "settings-app",
            "name": "系統設定",
            "version": "1.0.0",
            "main": "main.js",
            "type": "Window",
            "icon": "icon.svg",
            "permissions": [
                "window.create",
                "event.subscribe.window.ui",
                "event.emit.window.ui",
                "env.library.load",
                "settings.read",
                "settings.write",
                "notification.send",
                "network.status",
                "network.manage",
                "registry.read",
                "registry.write"
            ],
            "maxInstances": 1
        }
    ]
}
