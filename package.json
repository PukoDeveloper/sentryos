{
  "name": "sentryos-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter sentryos dev",
    "build": "pnpm --filter sentryos-sdk build && pnpm --filter sentryos build",
    "build:sdk": "pnpm --filter sentryos-sdk build",
    "preview": "pnpm --filter sentryos preview"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
